@startuml previlageEscalation
title "Privilege Escalation Risk Rule"


rectangle "LHS : User account is compromised and compromised user has write access to a sensitive file " as LHS_BOX #line:gray {

  object "user" as user_lhs <<User>> 
  object "victimEmail" as victimEmail_lhs  <<EmailAccount>> {

    compromised = true
    role = user
  }

  object "file" as file_lhs {
    isSensitive = true
    tampered = false
  }
  user_lhs -up-> victimEmail_lhs : owns
  victimEmail_lhs -right-> file_lhs : can_write
  
}

rectangle "Outcome 1 : Attacker successfully modifies file to escalate privileges" as OUTCOME_BOX_1 #line:gray {

  object "user" as user1 <<User>> #dddddd
  object "victimEmail" as victimEmail1 <<EmailAccount>> #dddddd {
    compromised = true  
    role = admin
    status= active
  }
  
   object "EmailAccount" as userEmail1 <<EmailAccount>> #dddddd {
    compromised = false  
    role = user
  }
  object "file" as file1 <<File>> #dddddd {
    isSensitive = true
    tampered = true
  }
  victimEmail1 .[#Green]up.> userEmail1 : manages
  user1 -up-> victimEmail1 : owns
  victimEmail1 -right-> file1 : can_write

}

rectangle "Outcome 2 : Attack attempt triggers security alert (e.g., file integrity monitoring)" as OUTCOME_BOX_2 #line:gray {
  
  object "user" as user2 <<User>> #dddddd
  object "victimEmail" as victimEmail2 <<EmailAccount>> #dddddd {
    compromised = true 
    role = user
  }
   object "file" as file2  <<File>> {
    isSensitive = true    
    tampered = false
  }
  object "Attacker" as attcker2 <<Attacker>> #ccffcc {
  }
  object "securityAlert" as securityAlert2 <<SecurityAlert>> #ccffcc {
    type = "file_modification_activity"
  }
  
  user2 -up-> victimEmail2 : owns
  attcker2 .[#Green]left.> victimEmail2 : targets

  securityAlert2 .[#Green].> victimEmail2 : alerts 
  victimEmail2 -left-> file2 : can_write


}

rectangle "Outcome 3 : Sysadmin detects and revokes file permissions before attack succeeds" as OUTCOME_BOX_3 #line:gray {

  object "user" as user3 <<User>> #dddddd
  object "victimEmail" as victimEmail3 <<EmailAccount>> #dddddd {
    compromised = true
    role = user
    status = suspended
  }
  object "file" as file3 <<File>> {
    isSensitive = true
    tampered = true
  }
   object "Attacker" as attcker3 <<Attacker>> #ccffcc {
  }
  object "EmailAccount" as sysadmin {
    role = admin
  } 

  attcker3 .[#Green]left.> victimEmail3 : targets
  user3 -up-> victimEmail3 : owns
  victimEmail3 -.[#7a9df4]left.-> file3 : can_write
  sysadmin --> victimEmail3 : manages
  sysadmin .[#Green].> file3 : can_write

}

@enduml