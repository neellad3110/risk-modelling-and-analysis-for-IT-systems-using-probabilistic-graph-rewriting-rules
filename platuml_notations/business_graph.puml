@startuml BUSINESS_GRAPH_TYPED
title "Business Graph with Organizational Hierarchy (Typed)"

skinparam object {
  BackgroundColor<<Organization>> #E3E3E3
  BackgroundColor<<Sales>> #EAD1DC
  BackgroundColor<<Engineering>> #EAD1DC
  BackgroundColor<<IT>> #EAD1DC
  BackgroundColor<<HR>> #EAD1DC
  BackgroundColor<<User>> #D1E8FF
  BackgroundColor<<Device>> #FFF2CC
  BackgroundColor<<Server>> #F4CCCC
  BackgroundColor<<Host>> #D5E8D4
  BackgroundColor<<EmailAccount>> #FFE6CC
  BackgroundColor<<Credentials>> #D0CECE
  BackgroundColor<<CredentialHash>> #F3E2A9
  BackgroundColor<<File>> #F9CB9C
  BackgroundColor<<Service>> #A2C4C9
}


object "org_1 : Organization" as org_1 <<Organization>>  {
  name = "ABC Software Inc."
}


object "dept_Sales : Sales" as dept_Sales <<Sales>>  {
  name = "Sales"
}
object "dept_Eng : Engineering" as dept_Eng <<Engineering>>  {
  name = "Engineering"
}
object "dept_IT : IT" as dept_IT <<IT>>  {
  name = "IT"
}
object "dept_HR : HR" as dept_HR <<HR>>  {
  name = "HR"
}
object "user_EMP001 : User" as user_EMP001 <<User>>  {
  name = "Alice"
}
object "user_EMP002 : User" as user_EMP002 <<User>>  {
  name = "Bob"
}
object "user_EMP003 : User" as user_EMP003 <<User>>  {
  name = "Charlie"
}
object "user_EMP004 : User" as user_EMP004 <<User>>  {
  name = "Diana"
}

object "device_EMP001 : Device" as device_EMP001 <<Device>>  {
  deviceType = "laptop"
  os = "Windows 10"
  accepts_ntlm = true
}
object "device_EMP002 : Device" as device_EMP002 <<Device>>  {
  deviceType = "laptop"
  os = "Ubuntu"
  accepts_ntlm = false
}
object "device_EMP003 : Device" as device_EMP003 <<Device>>  {
  deviceType = "desktop"
  os = "Windows 10"
  accepts_ntlm = false
}
object "device_EMP004 : Device" as device_EMP004 <<Device>>  {
  deviceType = "desktop"
  os = "Windows 10"
  accepts_ntlm = false
}


object "email_EMP001 : EmailAccount" as email_EMP001 <<EmailAccount>>  {
  role = "user"
