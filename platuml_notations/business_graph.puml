  status = "active"
  compromised = false
}
object "email_EMP002 : EmailAccount" as email_EMP002 <<EmailAccount>>  {
  role = "user"
  domain = "example.com"
  status = "active"
  compromised = false
}
object "email_EMP003 : EmailAccount" as email_EMP003 <<EmailAccount>>  {
  role = "admin"
  domain = "example.com"
  status = "active"
  compromised = false
}
object "email_EMP004 : EmailAccount" as email_EMP004 <<EmailAccount>>  {
  role = "user"
  domain = "example.com"
  status = "active"
  compromised = false
}

object "server1 : Server" as server1 <<Server>>  {
  name = "RDP-Server"
  os = "Windows Server 2019"
  accepts_ntlm = true
}
object "server2 : Server" as server2 <<Server>>  {
  name = "DB-Server"
  os = "Ubuntu 20.04"
  accepts_ntlm = false
}


object "host1 : Host" as host1 <<Host>>  {
  os = "Windows"
  compromised = false
  accepts_ntlm = true
}
object "host2 : Host" as host2 <<Host>>  {
  os = "Ubuntu"
  compromised = false
  accepts_ntlm = false
}


object "rdp_service1 : Service" as rdp_service1 <<Service>>  {
  type = "RDP"
  exposed = true
}
object "file1 : File" as file1 <<File>>  {
  name = "config.sh"
  isSensitive = true
  tampered = false
}
object "file2 : File" as file2 <<File>>  {
  name = "secrets.txt"
  isSensitive = true
  tampered = false
}


object "cred_EMP001 : Credentials" as cred_EMP001 <<Credentials>>  {
  owner = "user_EMP001"
  reused = false
  compromised = false
}
object "cred_EMP002 : Credentials" as cred_EMP002 <<Credentials>>  {
  owner = "user_EMP002"
  reused = true
  compromised = false
}


object "hash_EMP003 : CredentialHash" as hash_EMP003 <<CredentialHash>>  {
  owner = "user_EMP003"
  stolen = false
}

org_1 -- dept_Sales : has_department
org_1 -- dept_Eng : has_department
org_1 -- dept_IT : has_department
org_1 -- dept_HR : has_department

dept_Sales -- user_EMP001 : employs
dept_Eng -- user_EMP002 : employs
dept_IT -- user_EMP003 : employs
dept_HR -- user_EMP004 : employs

email_EMP001 -- device_EMP001 : uses
email_EMP002 -- device_EMP002 : uses
email_EMP003 -- device_EMP003 : uses
email_EMP004 -- device_EMP004 : uses

email_EMP003 -- email_EMP001 : manages
email_EMP003 -- email_EMP002 : manages
email_EMP003 -- email_EMP004 : manages

user_EMP001 -- email_EMP001 : owns
user_EMP002 -- email_EMP002 : owns
user_EMP003 -- email_EMP003 : owns
user_EMP004 -- email_EMP004 : owns

server1 -- host1 : runs_on
server2 -- host2 : runs_on

host1 -- rdp_service1 : runs

email_EMP002 -- file1 : can_write
email_EMP003 -- file2 : can_read

user_EMP001 -- cred_EMP001 : has_credentials
user_EMP002 -- cred_EMP002 : has_credentials
user_EMP003 -- hash_EMP003 : has_hash

host1 -- host2 : can_access
email_EMP003 -- host1 : credentials_stored_on

@enduml