  malicious = true
}

' === DNS CHANNEL ===
object dns1 <<DNSChannel>> {
  active = true
}

' === SCHEDULED TASK ===
object schedtask1 <<ScheduledTask>> {
  persistent = true
}

' === REGISTRY ENTRY ===
object regkey1 <<RegistryEntry>> {
  type = run_key
  malicious = true
}

' === NETWORK ZONES ===
object dmz <<NetworkZone>> {
  name = DMZ
}
object internal <<NetworkZone>> {
  name = Internal
}

' === ATTACKER ===
object attacker1 <<Attacker>> {
  origin = external
}

' === RELATIONS ===
EMP001 -- email_EMP001 : owns
EMP002 -- email_EMP002 : owns
EMP001 -- cred_EMP001 : has_credentials
EMP002 -- cred_EMP002 : has_credentials
EMP003 -- hash_EMP003 : has_hash
EMP001 -- device_EMP001 : owns_device
EMP002 -- device_EMP002 : owns_device

device_EMP001 -- av1 : installed_on
server1 -- edr1 : installed_on

EMP002 -- file1 : can_write
EMP003 -- file2 : can_read
EMP003 -- server2 : has_permission
EMP001 -- server1 : connected_to

server1 -- dmz : resides_in
server2 -- internal : resides_in

EMP001 -- EMP003 : trusts
EMP003 -- EMP002 : manager_of

server1 -- rdp_service1 : runs
host1 -- rdp_service1 : runs

web_app1 -- server1 : exposed_on
server1 -- script1 : runs

usb1 -- host1 : inserted_into
host1 -- dns1 : uses
schedtask1 -- host1 : runs_on
regkey1 -- host1 : on_host

@enduml