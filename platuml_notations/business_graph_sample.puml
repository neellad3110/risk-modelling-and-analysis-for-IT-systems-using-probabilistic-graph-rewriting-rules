object av1 <<SecurityTool>> {
  toolType = antivirus
  active = true
}
object edr1 <<SecurityTool>> {
  toolType = EDR
  active = true
}

' === FILES ===
object file1 <<File>> {
  name = config.sh
  canRead = true
  canWrite = true
  isSensitive = false
