{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Groove Risk Rule",
  "type": "object",
  "properties": {
    "risk_specification": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": ["string", "number"] },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "mitre_attack_id": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "preconditions": { "type": "array", "items": { "type": "string" } },
              "postconditions": { "type": "array", "items": { "type": "string" } },
              "risk_pattern": {
                "type": "object",
                "properties": {
                  "lhs": {
                    "type": "object",
                    "properties": {
                      "nodes": {
                        "type": "array",
                        "items": { "$ref": "#/$defs/nodePattern" }
                      },
                      "edges": {
                        "type": "array",
                        "items": { "$ref": "#/$defs/edgePattern" }
                      }
                    },
                    "required": ["nodes"]
                  }
                },
                "required": ["lhs"]
              },
              "attack_rate": {
                "type": "object",
                "properties": {
                  "rate_per_year": { "type": "number" },
                  "scope": { "type": "string" }
                }
              },
              "outcomes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "probability": { "type": "number", "minimum": 0, "maximum": 1 },
                    "cost": { "type": "number" },
                    "followup_attacks": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "nodes": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/nodePattern" }
                    },
                    "edges": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/edgePattern" }
                    }
                  },
                  "required": ["name"]
                }
              }
            },
            "required": ["id", "title", "risk_pattern", "outcomes"]
          }
        }
      },
      "required": ["rules"]
    }
  },
  "$defs": {
    "nodePattern": {
      "type": "object",
      "properties": {
        "type": { "type": "string" }, 
        "op": {
          "type": "string",
          "enum": ["type", "new", "del", "not"]
        }, 
        "bind": { "type": "string" }, 
        "role": {
          "type": "string",
          "enum": ["input", "output", "internal"]
        },
        "attributes": {
          "type": "object",
          "patternProperties": {
            "^(let|test):[a-zA-Z_][a-zA-Z0-9_]*$": {}
          },
          "additionalProperties}": false
        },
        "match_group": { "type": "string" },
        "comment": { "type": "string" }
      },
      "required": ["type"]
    },
    "edgePattern": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "op": {
          "type": "string",
          "enum": ["type", "new", "del", "not"]
        }, 
        "source": { "type": "string" }, 
        "target": { "type": "string" }, 
        "attributes": {
          "type": "object",
          "patternProperties": {
            "^(let|test):[a-zA-Z_][a-zA-Z0-9_]*$": {}
          },
          "additionalProperties": false
        },
        "comment": { "type": "string" }
      },
      "required": ["type", "source", "target"]
    }
  }
}