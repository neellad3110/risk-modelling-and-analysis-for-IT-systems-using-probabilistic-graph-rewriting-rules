{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/typeGraphs.schema.json",
  "title": "Typed Graph Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "nodes", "edges"],
    "properties": {
      "id": {
        "type": "string"
      },
      "typedOver": {
        "type": "string",
        "minLength": 1
      },
      "nodes": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            },
            "attributes": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "not": { "const": null },
                "anyOf": [
                  { "type": "string", "minLength": 1 },
                  { "type": "boolean" },
                  { "type": "integer" },
                  { "type": "number" },
                  { "type": "array", "minItems": 1 }
                ]
              }
            }, 
            "formulas": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "dependentRequired": {
              "$comment": "the check if attributes have at least one field is validated in the sub-schema of attributes",
              "formulas": ["attributes"]
            }
          },
          "additionalProperties": false
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "type": "object",
          "$comment": "Edges must have a source and target node. Thus, dengling edges are not allowed, but maybe the references are wrong.",
          "required": ["id", "source", "target"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "target": {
              "type": "string",
              "minLength": 1
            },
            "attributes": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "not": { "const": null },
                "anyOf": [
                  { "type": "string", "minLength": 1 },
                  { "type": "boolean" },
                  { "type": "integer" },
                  { "type": "number" },
                  { "type": "array", "minItems": 1 }
                ]
              }
            }, 
            "formulas": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "dependentRequired": {
              "$comment": "the check if attributes have at least one field is validated in the sub-schema of attributes",
              "formulas": ["attributes"]
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
