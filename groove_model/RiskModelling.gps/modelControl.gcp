function phishingAttack_Rule(out node victimEmail)
{
    phishingAttack(out victimEmail); // risk pattern
    phishingAttack_User_clicked_link_and_entered_credentials(victimEmail) | 
    phishingAttack_User_clicked_link_but_did_not_enter_credentials(victimEmail) | 
    phishingAttack_User_ignored_the_email(victimEmail)| 
    phishingAttack_User_reported_the_phishing_attempt(victimEmail); 
}

function privilegeEscalation_Rule(out node compromisedEmail)
{
    privilegeEscalation(out compromisedEmail);
    privilegeEscalation_attacker_successfully_modifies_file_to_escalate_priviledges(compromisedEmail)|
    privilegeEscalation_attack_attempt_triggers_security_alert_by_file_integrity_monitoring(compromisedEmail)|
    privilegeEscalation_sysadmin_detects_and_revokes_file_permissions_before_attack_succeeds(compromisedEmail);
}

function remoteServiceExploitation_Rule(out node userEmail)
{
	remoteServiceExploitation(out userEmail);
	remoteServiceExploitationAttacker_logged_in_via_RDP_and_gained_control(userEmail)|
	remoteServiceExploitation_RDP_login_attempt_failed_without_detection(userEmail)|
	remoteServiceExploitation_multiple_failed_RDP_login_attempts_security_alert_triggered_systemAdmin_closed_RDP_port(userEmail);
}

function credentialDumping_Rule(out node compromisedHost){

	credentialDumping(out compromisedHost);
	credentialDumping_attacker_dumps_admin_credentials(compromisedHost)|
	credentialDumping_endpoint_security_detected_the_attempt(compromisedHost)|
	credentialDumping_attempt_failed_silently(compromisedHost);

}

function passTheHash_lateralMovement_Rule(out node compromisedHost){

	passTheHash_lateralMovement(out compromisedHost);
	passTheHash_lateralMovement_Attacker_successfully_authenticated_using_NTLM_hash_and_compromised_host(compromisedHost)|
	passTheHash_lateralMovement_Suspicious_login_attempt_detected_and_flagged(compromisedHost)|
	passTheHash_lateralMovement_Authentication_attempt_failed_and_remained_undetected(compromisedHost);
}

function unauthorized_script_execution_Rule(out node compromisedEmail2){

	UnauthorizedScriptExecution(out compromisedEmail2);
	UnauthorizedScriptExecution_Script_is_executed_successfully(compromisedEmail2)|
	UnauthorizedScriptExecution_Attack_attempt_triggers_security_alert(compromisedEmail2)|
	UnauthorizedScriptExecution_Script_detected_during_execution_by_antivirus_or_EDR(compromisedEmail2)|
	UnauthorizedScriptExecution_Script_Execution_failed_silently(compromisedEmail2);

}

function maliciousUSBDevice_Rule(out node compromisedEmail3){
	maliciousUSBDevice(out compromisedEmail3);
	maliciousUSBDevice_Payload_executed_but_user_account_is_not_compromised(compromisedEmail3)|
	maliciousUSBDevice_Payload_executed_and_host_was_compromised(compromisedEmail3)|
	maliciousUSBDevice_Antivirus_detected_and_blocked_payload_execution(compromisedEmail3)|
	maliciousUSBDevice_Device_was_removed_before_execution(compromisedEmail3);
}

function ransomwareDeployment_Rule(out node compromisedEmail4){
	ransomwareDeployment(out compromisedEmail4);
	ransomwareDeployment_Attacker_encrypted_the_file_and_demanded_ransom_for_decryption(compromisedEmail4)|
	ransomwareDeployment_Ransom_paid_to_attacker_and_files_decrypted(compromisedEmail4)|
	ransomwareDeployment_Files_restored_from_backup_permission_revoked_and_user_account_was_recovered_attack_mitigated(compromisedEmail4)|
	ransomwareDeployment_Security_alert_triggered_and_file_permission_revoked_before_encryption(compromisedEmail4)|
	ransomwareDeployment_attack_failed_silently(compromisedEmail4);

}

function dosAttack_Rule(out node compromisedService){
	DOSAttack(out compromisedService);
	DOSAttack_Service_unavailable(compromisedService)|
	DOSAttack_attack_detected_and_mitigated(compromisedService)|
	DOSAttack_attaker_degrades_the_service_partially(compromisedService)|
	DOSAttack_attack_failed_silently(compromisedService);
	
}

function trustedRelationship_Rule(out node compromisedEmail5){

	trustedRelationship(out compromisedEmail5);
	trustedRelationship_Attacker_user_abuses_trust_and_gains_access_to_sensitive_file_to_extract_data(compromisedEmail5)|
	trustedRelationship_Suspicious_activity_detected_and_alert_triggered(compromisedEmail5)|
	trustedRelationship_attack_failed_silently(compromisedEmail5);
}



function attack_pipeline(){

	node victimEmail,compromisedAccount,compromisedEmail1,userEmail,compromisedHost1,compromisedHost2,compromisedEmail2,compromisedEmail3,compromisedEmail4,compromisedService,compromisedEmail5;

	// independent attacks
	phishingAttack_Rule(out victimEmail) |
    remoteServiceExploitation_Rule(out userEmail) |
    maliciousUSBDevice_Rule(out compromisedEmail3) |
    trustedRelationship_Rule(out compromisedEmail5) |
    dosAttack_Rule(out compromisedService) |
    
    // Follow-up attacks
    privilegeEscalation_Rule(out compromisedEmail1) |
    credentialDumping_Rule(out compromisedHost1) |
    unauthorized_script_execution_Rule(out compromisedAccount) |
    passTheHash_lateralMovement_Rule(out compromisedHost2) |
    ransomwareDeployment_Rule(out compromisedEmail4);
}

alap attack_pipeline();




